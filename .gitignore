__pycache__/
*.py[cod]
.pytest_cache/
.venv/
config/config.json
voices/samples/*
!voices/samples/.gitkeep
output/*
!output/.gitkeep
*.wav
*.mp3
*.flac
*.ogg
.hermes_overnight.log
.hermes_overnight_prompt.md
.DS_Store

# Keep predownloaded build assets in Git so Docker builds can run offline,
# even when their file extensions match the generic audio ignores above.
!vendor/model-assets/**
# Ignore Hugging Face cache runtime noise; blobs/snapshots/refs are the useful assets.
vendor/model-assets/huggingface/hub/.locks/
vendor/model-assets/huggingface/xet/
